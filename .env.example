# ===============================================
# DUWHITE Gestión - Variables de Entorno
# ===============================================
# Copiar este archivo a .env y configurar los valores

# -----------------------------------------------
# Backend
# -----------------------------------------------

# Base de datos PostgreSQL
DATABASE_URL=postgresql://duwhite:duwhite_secret@localhost:5432/duwhite_gestion

# Seguridad JWT
SECRET_KEY=tu-clave-secreta-muy-segura-de-al-menos-32-caracteres
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis para Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Email SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=gestion@duwhite.com

# Datos de la empresa
EMPRESA_NOMBRE=DUWHITE
EMPRESA_CUIT=XX-XXXXXXXX-X
EMPRESA_DIRECCION=Córdoba, Argentina
EMPRESA_CONDICION_IVA=Responsable Inscripto

# Debug
DEBUG=true

# -----------------------------------------------
# Frontend
# -----------------------------------------------
VITE_API_URL=http://localhost:8000/api/v1
