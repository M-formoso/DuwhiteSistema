# Backend Environment Variables

# Database
DATABASE_URL=postgresql://duwhite:duwhite_secret@localhost:5432/duwhite_gestion

# Security
SECRET_KEY=tu-clave-secreta-super-segura-cambiar-en-produccion
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis/Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# CORS (separados por coma)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Email SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASSWORD=tu-app-password
EMAIL_FROM=gestion@duwhite.com

# Empresa (DUWHITE S.R.L. - dependencia AGENCIA SEDE CORDOBA)
EMPRESA_NOMBRE=DUWHITE
EMPRESA_RAZON_SOCIAL=DUWHITE S.R.L.
EMPRESA_CUIT=30-71925569-4
EMPRESA_DIRECCION=Córdoba, Argentina
EMPRESA_LOCALIDAD=Córdoba
EMPRESA_PROVINCIA=Córdoba
EMPRESA_CONDICION_IVA=Responsable Inscripto
EMPRESA_IIBB=
EMPRESA_INICIO_ACTIVIDADES=2008-01-01

# Régimen "Pago en CBU informada" (RG 5762/25 del 20/04/2026)
# Habilita Factura A pero exige imprimir leyenda + CBU en el comprobante.
# La CBU debe ser la misma que se informó a ARCA al solicitar la habilitación.
EMPRESA_CBU=
EMPRESA_BANCO=
EMPRESA_CUENTA_TITULAR=

# ARCA / AFIP - Facturación Electrónica (WSFEv1 + WSAA)
# Entorno: "homologacion" (testing) o "produccion"
AFIP_ENTORNO=homologacion
# PV 2 = "RECE para aplicativo y web services" (el único que sirve para WSFEv1)
AFIP_PUNTO_VENTA=2
# Ruta al certificado .crt emitido por AFIP y su clave privada .key
AFIP_CERT_PATH=/secrets/afip.crt
AFIP_KEY_PATH=/secrets/afip.key
AFIP_CACHE_DIR=/tmp/duwhite/afip

# Debug
DEBUG=true
